<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Toji Split" />
<title>Toji Split</title>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0A0C10; --surface:#12151C; --surface-2:#1A1E27; --border:#232834;
  --accent:#3B82F6; --accent-soft:#7DA9F0;
  --text:#EAEEF5; --text-dim:#6B7280; --text-faint:#424955;
  --nav-h:88px;
}
* { box-sizing:border-box; -webkit-tap-highlight-color:transparent; margin:0; padding:0; }
html,body { background:var(--bg); min-height:100vh; }
body { font-family:'Inter',sans-serif; color:var(--text); padding-top:env(safe-area-inset-top); }
button { font-family:inherit; cursor:pointer; color:inherit; }
input::-webkit-outer-spin-button,input::-webkit-inner-spin-button { -webkit-appearance:none; }
input[type=number] { -moz-appearance:textfield; }
.ab { font-family:'Archivo Black',sans-serif; }
svg { display:block; }
.bottom-spacer { height:var(--nav-h); }

/* NAV */
.bottom-nav { position:fixed; bottom:0; left:0; right:0; background:var(--surface); border-top:1px solid var(--border); display:flex; padding:10px 0 calc(12px + env(safe-area-inset-bottom)); z-index:40; }
.nav-btn { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; background:none; border:none; color:var(--text-faint); font-size:10px; font-weight:700; letter-spacing:0.5px; padding:2px 0; transition:color 0.15s; }
.nav-btn.active { color:var(--text); }
.nav-btn.active .nav-ic path { stroke:var(--accent); }

/* HOME */
.home-header { padding:26px 20px 6px; display:flex; justify-content:center; }
.brand-lockup { display:flex; align-items:center; gap:12px; }
.brand-word { font-size:30px; letter-spacing:-0.5px; }

/* RANK CARD */
.rank-card { margin:16px 20px 0; border-radius:20px; padding:22px; position:relative; overflow:hidden; background:var(--surface); border:1px solid var(--border); }
.rank-card-glow { position:absolute; top:-40%; right:-10%; width:200px; height:200px; border-radius:50%; filter:blur(60px); opacity:0.22; background:var(--accent); }
.rank-top { display:flex; align-items:center; gap:14px; position:relative; }
.rank-emblem-wrap { width:56px; height:56px; flex-shrink:0; }
.rank-label { font-size:10px; letter-spacing:2.5px; font-weight:700; color:var(--text-dim); }
.rank-name { font-size:26px; letter-spacing:-0.5px; margin-top:2px; }
.rank-pts { font-size:12.5px; color:var(--text-dim); margin-top:3px; }
.rank-bar-track { height:6px; background:var(--surface-2); border-radius:4px; margin-top:18px; overflow:hidden; }
.rank-bar-fill { height:100%; border-radius:4px; transition:width 0.5s ease; }
.rank-bar-labels { display:flex; justify-content:space-between; margin-top:7px; font-size:10px; color:var(--text-faint); font-weight:600; }
.rank-card-btn { display:block; width:calc(100% - 40px); text-align:left; cursor:pointer; }
.rank-card-arrow { margin-left:auto; align-self:center; opacity:0.7; }

/* RANK DETAIL VIEW */
.rank-next-card { margin:16px 20px 0; background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:24px 20px; display:flex; flex-direction:column; align-items:center; text-align:center; }
.rank-next-emblems { display:flex; align-items:center; gap:14px; margin-bottom:16px; }
.rank-next-cur { width:48px; height:48px; }
.rank-next-nxt { width:48px; height:48px; }
.rank-next-arrow { opacity:0.5; }
.rank-next-big { font-size:46px; line-height:1; color:var(--accent); }
.rank-next-label { font-size:12px; color:var(--text-dim); font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-top:5px; }
.ch-list { padding:0 20px; display:flex; flex-direction:column; gap:10px; }
.ch-row { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:13px 14px; display:flex; align-items:center; gap:12px; }
.ch-row.done { border-color:rgba(61,214,140,0.35); }
.ch-emblem { width:34px; height:34px; flex-shrink:0; }
.ch-info { flex:1; min-width:0; }
.ch-rank { font-size:11px; font-weight:800; letter-spacing:0.5px; color:var(--text-faint); }
.ch-task { font-size:14px; font-weight:700; margin-top:2px; }
.ch-bar-track { height:5px; background:var(--surface-2); border-radius:3px; margin-top:8px; overflow:hidden; }
.ch-bar-fill { height:100%; border-radius:3px; transition:width 0.5s ease; }
.ch-status { flex-shrink:0; min-width:42px; text-align:right; }
.ch-best { font-size:12px; font-weight:700; color:var(--text-dim); }
.ch-check { display:inline-flex; }

/* STAT CHIPS */
.stat-row { display:flex; gap:10px; padding:14px 20px 0; }
.stat-chip { flex:1; background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:13px 10px; display:flex; flex-direction:column; align-items:center; gap:5px; }
.stat-chip-ic { height:18px; }
.stat-chip-val { font-size:19px; }
.stat-chip-label { font-size:9.5px; color:var(--text-dim); letter-spacing:0.5px; text-transform:uppercase; }

/* STREAK FLAME CARD */
.streak-card { margin:16px 20px 0; background:var(--surface); border:1px solid var(--border); border-radius:20px; padding:24px 20px 20px; display:flex; flex-direction:column; align-items:center; position:relative; overflow:hidden; }
.streak-card.lit { border-color:rgba(255,138,30,0.4); }
.streak-glow { position:absolute; top:-30px; left:50%; transform:translateX(-50%); width:200px; height:200px; border-radius:50%; background:#FF8A1E; filter:blur(70px); opacity:0.22; pointer-events:none; }
.streak-flame { position:relative; height:64px; }
.streak-card.lit .streak-flame { animation:flameFlicker 2.4s ease-in-out infinite; transform-origin:center bottom; }
@keyframes flameFlicker { 0%,100%{ transform:scale(1) rotate(0deg);} 25%{ transform:scale(1.05,0.97) rotate(-1.5deg);} 50%{ transform:scale(0.97,1.04) rotate(1deg);} 75%{ transform:scale(1.03,0.99) rotate(-0.5deg);} }
.streak-num { font-size:54px; line-height:1; margin-top:6px; position:relative; }
.streak-unit { font-size:12px; color:var(--text-dim); font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-top:2px; position:relative; }

/* SWIPE DAY PREVIEW */
.swipe-section { padding:20px 0 4px; }
.swipe-viewport { overflow:hidden; padding:0 20px; touch-action:pan-y; }
.swipe-track { display:flex; transition:transform 0.38s cubic-bezier(.22,1,.36,1); will-change:transform; }
.swipe-card { flex:0 0 100%; box-sizing:border-box; background:var(--surface); border:1.5px solid var(--border); border-radius:22px; padding:30px 26px 22px; min-height:188px; display:flex; flex-direction:column; text-align:left; position:relative; overflow:hidden; transition:border-color 0.25s, transform 0.14s cubic-bezier(.34,1.56,.64,1); }
.swipe-card:active { transform:scale(0.975); }
.swipe-card-glow { position:absolute; top:-60px; right:-50px; width:160px; height:160px; border-radius:50%; filter:blur(60px); opacity:0.18; pointer-events:none; }
.swipe-day-num { font-size:13px; letter-spacing:2.5px; position:relative; }
.swipe-day-title { font-size:38px; line-height:1.05; margin-top:8px; letter-spacing:-0.5px; position:relative; }
.swipe-day-sub { font-size:14px; color:var(--text-dim); margin-top:8px; position:relative; }
.swipe-card-foot { margin-top:auto; padding-top:20px; display:flex; justify-content:space-between; align-items:flex-end; position:relative; }
.swipe-meta { font-size:12px; color:var(--text-faint); font-weight:600; }
.swipe-progress { font-size:12px; font-weight:700; }
.swipe-tap { font-size:12px; color:var(--text-faint); font-weight:600; letter-spacing:0.3px; }
.swipe-dots { display:flex; justify-content:center; gap:7px; padding:18px 0 4px; }
.swipe-dot { width:7px; height:7px; border-radius:4px; background:var(--border); border:none; padding:0; transition:width 0.3s cubic-bezier(.22,1,.36,1), background 0.3s; }

/* DAY VIEW */
.day-hero { padding:22px 20px 18px; position:relative; }
.back-btn { background:var(--surface); border:1px solid var(--border); border-radius:10px; width:38px; height:38px; display:flex; align-items:center; justify-content:center; margin-bottom:16px; }
.day-hero-label { font-size:11px; letter-spacing:3px; color:var(--text-dim); font-weight:700; }
.day-hero-title { font-size:34px; letter-spacing:-0.5px; margin-top:2px; }
.day-hero-sub { font-size:13px; color:var(--text-dim); margin-top:2px; }
.progress-track { height:5px; background:var(--surface-2); border-radius:4px; margin-top:16px; overflow:hidden; }
.progress-fill { height:100%; border-radius:4px; transition:width 0.3s ease; }
.progress-label { font-size:11px; color:var(--text-dim); margin-top:7px; font-weight:600; }

/* EXERCISE */
.ex-list { padding:8px 16px 0; display:flex; flex-direction:column; gap:12px; }
.ex-card { background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:14px 14px 10px; transition:border-color 0.2s; }
.ex-header { display:flex; align-items:flex-start; margin-bottom:11px; }
.ex-name { font-size:15px; font-weight:700; line-height:1.25; flex:1; }
.ex-meta { font-size:11.5px; color:var(--text-dim); margin-top:3px; }
.ex-badge { font-size:11px; font-weight:700; border:1px solid var(--border); border-radius:8px; padding:4px 9px; color:var(--text-faint); white-space:nowrap; }
.set-grid { display:flex; flex-direction:column; gap:8px; }
.set-head { display:grid; grid-template-columns:28px 1fr 1fr 40px; gap:8px; align-items:center; padding:0 2px 2px; }
.set-col-label { font-size:9.5px; color:var(--text-faint); font-weight:700; letter-spacing:0.8px; text-align:center; }
.set-row { display:grid; grid-template-columns:28px 1fr 1fr 40px; gap:8px; align-items:center; }
.set-num { font-size:13px; font-weight:800; text-align:center; color:var(--text-faint); }
.stepper { display:flex; align-items:center; background:var(--surface-2); border:1px solid var(--border); border-radius:11px; overflow:hidden; height:42px; transition:border-color 0.18s; }
.stepper:focus-within { border-color:var(--accent); }
.step-btn { width:34px; height:100%; border:none; background:transparent; color:var(--text-dim); font-size:20px; font-weight:600; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:background 0.12s, color 0.12s, transform 0.1s; }
.step-btn:active { transform:scale(0.85); color:var(--text); }
.step-input { flex:1; min-width:0; background:transparent; border:none; color:var(--text); font-size:16px; font-weight:700; text-align:center; padding:0; width:100%; -moz-appearance:textfield; }
.step-input::-webkit-outer-spin-button,.step-input::-webkit-inner-spin-button { -webkit-appearance:none; margin:0; }
.step-input:focus { outline:none; }
.step-input::placeholder { color:var(--text-faint); font-weight:600; }
.check-btn { width:40px; height:40px; border-radius:12px; border:1.5px solid var(--border); display:flex; align-items:center; justify-content:center; background:transparent; }

/* FINISH BUTTON */
.finish-btn { margin:22px 16px 0; width:calc(100% - 32px); background:var(--accent); color:#0A0C10; border:none; border-radius:14px; padding:17px; font-size:15px; font-weight:800; display:flex; align-items:center; justify-content:center; gap:9px; letter-spacing:0.3px; }
.finish-btn:active { background:var(--accent-soft); }
.finish-btn.disabled { background:var(--surface-2); color:var(--text-faint); }

/* TIMER */
.timer-overlay,.modal-overlay { position:fixed; inset:0; background:rgba(5,7,10,0.9); backdrop-filter:blur(8px); display:flex; align-items:center; justify-content:center; z-index:60; padding:20px; }
.timer-card { background:var(--surface); border:1px solid var(--border); border-radius:24px; padding:32px 28px; display:flex; flex-direction:column; align-items:center; position:relative; width:min(320px,88vw); }
.timer-close { position:absolute; top:14px; right:14px; background:none; border:none; }
.timer-ring-outer { width:176px; height:176px; border-radius:50%; display:flex; align-items:center; justify-content:center; padding:8px; }
.timer-ring-inner { width:100%; height:100%; border-radius:50%; background:var(--bg); display:flex; flex-direction:column; align-items:center; justify-content:center; }
.timer-time { font-size:44px; font-weight:800; letter-spacing:-1px; }
.timer-sub { font-size:11px; color:var(--text-dim); margin-top:4px; letter-spacing:2px; }
.timer-controls { display:flex; gap:10px; margin-top:26px; }
.timer-btn { background:var(--surface-2); border:1px solid var(--border); border-radius:12px; padding:11px 16px; font-size:13px; font-weight:700; min-width:54px; display:flex; align-items:center; justify-content:center; }
.timer-reset-btn { margin-top:14px; background:none; border:none; color:var(--text-faint); font-size:11.5px; font-weight:600; display:flex; align-items:center; gap:5px; }

/* FINISH MODAL */
.modal-sheet { background:var(--surface); border:1px solid var(--border); border-radius:24px; padding:30px 26px; display:flex; flex-direction:column; align-items:center; width:min(340px,90vw); text-align:center; }
.modal-emblem { width:64px; height:64px; margin-bottom:6px; }
.modal-eyebrow { font-size:11px; letter-spacing:3px; font-weight:700; color:var(--text-dim); margin-top:4px; }
.modal-title { font-size:20px; font-weight:800; margin-top:8px; }
.modal-title-lg { font-size:28px; letter-spacing:-0.5px; margin-top:2px; }
.modal-text { font-size:13px; color:var(--text-dim); line-height:1.6; margin-top:12px; }
.modal-points { font-size:40px; letter-spacing:-1px; color:var(--accent-soft); margin-top:14px; }
.modal-points span { font-size:16px; color:var(--text-dim); font-weight:700; }
.rank-up-badge { margin-top:14px; background:linear-gradient(90deg,var(--accent),var(--accent-soft)); color:#0A0C10; font-size:12px; font-weight:800; letter-spacing:0.5px; padding:8px 16px; border-radius:20px; }
.modal-total { font-size:12px; color:var(--text-dim); margin-top:14px; font-weight:600; }
.modal-actions { display:flex; gap:10px; margin-top:24px; width:100%; }
.modal-btn-ghost { flex:1; background:var(--surface-2); border:1px solid var(--border); border-radius:13px; padding:14px; font-size:14px; font-weight:700; }
.modal-btn-primary { flex:1; background:var(--accent); color:#0A0C10; border:none; border-radius:13px; padding:14px; font-size:14px; font-weight:800; }
.modal-btn-primary.full { width:100%; margin-top:24px; }

/* STATS */
.stats-header { padding:28px 20px 18px; }
.stats-kicker { font-size:11px; letter-spacing:3px; color:var(--text-faint); font-weight:700; margin-bottom:3px; }
.stats-title { font-size:32px; letter-spacing:-0.5px; }
.section-label { font-size:11px; letter-spacing:2.5px; color:var(--text-faint); font-weight:700; padding:0 20px; margin-bottom:11px; }
.ranks-grid { padding:0 20px; display:flex; flex-direction:column; gap:8px; margin-bottom:26px; }
.rank-row { display:flex; align-items:center; gap:13px; background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:11px 14px; }
.rank-row-emblem { width:30px; height:30px; flex-shrink:0; }
.rank-row-info { flex:1; }
.rank-row-name { font-size:14px; font-weight:700; }
.rank-row-pts { font-size:11px; color:var(--text-dim); margin-top:1px; }
.rank-row-status { font-size:10px; font-weight:700; letter-spacing:0.5px; }
.pr-list { padding:0 20px; display:flex; flex-direction:column; gap:8px; margin-bottom:26px; }
.pr-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:13px 14px; }
.pr-card-header { display:flex; justify-content:space-between; align-items:flex-start; }
.pr-card-name { font-size:13px; font-weight:700; }
.pr-card-pts { font-size:10px; color:var(--text-dim); font-weight:600; margin-top:2px; }
.pr-card-weight { font-size:16px; font-weight:800; color:var(--accent-soft); }
.mini-chart { width:100%; display:flex; align-items:flex-end; gap:4px; margin-top:10px; }
.mini-bar-col { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; }
.mini-bar { width:100%; border-radius:3px 3px 0 0; min-height:4px; background:var(--accent); opacity:0.55; }
.mini-bar-label { font-size:8px; color:var(--text-faint); font-weight:600; }
.hist-list { padding:0 20px; display:flex; flex-direction:column; gap:8px; }
.hist-row { display:flex; align-items:center; gap:11px; background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:11px 12px; }
.hist-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.hist-info { flex:1; }
.hist-day { font-size:12.5px; font-weight:700; }
.hist-date { font-size:11px; color:var(--text-dim); margin-top:1px; }
.hist-pts { font-size:12px; font-weight:800; color:var(--accent-soft); }
.empty-state { text-align:center; padding:30px 20px; color:var(--text-faint); font-size:13px; line-height:1.6; }
.stat-empty { margin:16px 20px 0; background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:26px 22px; text-align:center; color:var(--text-dim); font-size:13.5px; line-height:1.6; }
/* PR detail rows */
.pr-row { display:flex; align-items:center; justify-content:space-between; gap:12px; background:var(--surface); border:1px solid var(--border); border-radius:13px; padding:14px 16px; }
.pr-main { min-width:0; }
.pr-name { font-size:14.5px; font-weight:700; }
.pr-reps { font-size:11.5px; color:var(--text-faint); font-weight:600; margin-top:2px; }
.pr-weight { font-size:24px; color:var(--accent-soft); white-space:nowrap; }
.pr-kg { font-size:13px; font-weight:700; margin-left:2px; color:var(--text-dim); }
/* mini stat summary */
.mini-stat-row { display:flex; gap:10px; padding:16px 20px 0; }
.mini-stat { flex:1; background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:16px 12px; text-align:center; }
.mini-stat-val { font-size:26px; line-height:1; }
.mini-stat-lbl { font-size:10.5px; color:var(--text-dim); letter-spacing:0.5px; text-transform:uppercase; font-weight:600; margin-top:6px; }
/* horizontal set bars */
.setbar-list { padding:0 20px; display:flex; flex-direction:column; gap:11px; }
.setbar-row { display:flex; align-items:center; gap:12px; }
.setbar-label { font-size:12.5px; font-weight:600; width:84px; flex-shrink:0; color:var(--text-dim); }
.setbar-track { flex:1; height:10px; background:var(--surface-2); border-radius:5px; overflow:hidden; }
.setbar-fill { height:100%; border-radius:5px; min-width:2px; transition:width 0.5s cubic-bezier(.22,1,.36,1); }
.setbar-val { font-size:12.5px; font-weight:800; width:34px; text-align:right; flex-shrink:0; }

/* TOAST */
#toast { position:fixed; bottom:calc(var(--nav-h) + 16px); left:50%; transform:translateX(-50%) translateY(20px); background:var(--surface-2); border:1px solid var(--border); color:var(--text); font-size:13px; font-weight:600; padding:11px 18px; border-radius:12px; opacity:0; pointer-events:none; transition:all 0.25s; z-index:80; white-space:nowrap; }
#toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

/* INTRO / SPLASH */
#intro { position:fixed; inset:0; z-index:100; background:#0A0C10; display:flex; flex-direction:column; align-items:center; justify-content:center; transition:opacity 0.55s ease, visibility 0.55s ease; padding:env(safe-area-inset-top) 24px 0; }
#intro.hide { opacity:0; visibility:hidden; pointer-events:none; }
.intro-glow { position:absolute; top:50%; left:50%; width:340px; height:340px; transform:translate(-50%,-50%); border-radius:50%; background:var(--accent); filter:blur(90px); opacity:0.16; }
.intro-crest-btn { background:none; border:none; padding:0; position:relative; z-index:2; transition:transform 0.3s cubic-bezier(.34,1.56,.64,1); animation:crestFloat 3s ease-in-out infinite; }
.intro-crest-btn:active { transform:scale(0.92); }
@keyframes crestFloat { 0%,100%{ transform:translateY(0);} 50%{ transform:translateY(-8px);} }
.intro-crest-ring { position:absolute; inset:-20px; border:1.5px solid var(--border); border-radius:50%; z-index:-1; animation:ringPulse 3s ease-in-out infinite; }
.intro-touch { margin-top:38px; font-size:13px; letter-spacing:2.5px; color:var(--text-faint); font-weight:600; text-transform:uppercase; animation:touchFade 2.2s ease-in-out infinite; }
@keyframes touchFade { 0%,100%{ opacity:0.35; } 50%{ opacity:0.85; } }
@keyframes ringPulse { 0%,100%{ opacity:0.45; transform:scale(1);} 50%{ opacity:0.12; transform:scale(1.1);} }

/* APP HIDDEN UNTIL ENTER (prevents flash) */
#app { opacity:0; transform:translateY(10px) scale(0.99); transition:opacity 0.55s ease, transform 0.55s cubic-bezier(.22,1,.36,1); }
#app.entered { opacity:1; transform:none; }

/* VIEW + STAGGER ENTRANCE */
@keyframes fadeUp { from{ opacity:0; transform:translateY(12px);} to{ opacity:1; transform:none;} }
.view-anim > * { animation:fadeUp 0.42s cubic-bezier(.22,1,.36,1) both; }
.view-anim > *:nth-child(1){ animation-delay:.03s; }
.view-anim > *:nth-child(2){ animation-delay:.09s; }
.view-anim > *:nth-child(3){ animation-delay:.15s; }
.view-anim > *:nth-child(4){ animation-delay:.21s; }
.view-anim > *:nth-child(5){ animation-delay:.27s; }
.view-anim > *:nth-child(6){ animation-delay:.33s; }

/* BUTTON MICRO-INTERACTIONS */
.nav-btn, .finish-btn, .back-btn,
.timer-btn, .modal-btn-primary, .modal-btn-ghost, .stat-chip, .rank-card-btn {
  transition: transform .14s cubic-bezier(.34,1.56,.64,1), background .15s ease, border-color .15s ease;
}
.finish-btn:active, .back-btn:active,
.timer-btn:active, .modal-btn-primary:active, .modal-btn-ghost:active, .stat-chip:active, .rank-card-btn:active { transform:scale(0.98); }
.nav-btn:active { transform:scale(0.9); }
.check-btn { transition:transform .14s cubic-bezier(.34,1.56,.64,1), background .15s ease, border-color .15s ease; }
.check-btn:active { transform:scale(0.86); }
@keyframes popIcon { 0%{ transform:scale(0.3);} 55%{ transform:scale(1.25);} 100%{ transform:scale(1);} }
.check-btn.pop svg { animation:popIcon .3s cubic-bezier(.34,1.56,.64,1); }

@media (prefers-reduced-motion: reduce){
  .intro-crest-btn,.intro-crest-ring,.intro-touch { animation:none; }
  .view-anim > *, #app, .check-btn.pop svg, .streak-card.lit .streak-flame { animation:none; transition:none; }
  #app { opacity:1; transform:none; }
}
</style>
</head>
<body>
<div id="intro">
