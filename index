function renderStats(){
  const pts=totalPoints(), ri=getRank(pts);
  const prs=computePRs();
  const prEntries=Object.entries(prs).sort((a,b)=>b[1].weight-a[1].weight);

  const ranksHtml=RANKS.map((r,i)=>{
    const isCur=i===ri, unlocked=pts>=r.min;
    return `<div class="rank-row" style="${isCur?'border-color:var(--accent)':''}">
      <div class="rank-row-emblem">${rankEmblem(r.tier,30,unlocked)}</div>
      <div class="rank-row-info">
