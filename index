  const header=statHeader("DAYS COMPLETED", total+" day"+(total===1?"":"s"), "Workouts you've finished", "var(--accent)");
  if(!total) return header+emptyState("No days completed yet. Hit \u201cFinish Day\u201d after a workout to log it here.")+`<div class="bottom-spacer"></div>`;
  const totalPts=totalPoints();
  const summary=`<div class="mini-stat-row">
    <div class="mini-stat"><div class="mini-stat-val ab" style="color:#FF8A1E">${streak}</div><div class="mini-stat-lbl">Day Streak</div></div>
    <div class="mini-stat"><div class="mini-stat-val ab">${totalPts.toLocaleString()}</div><div class="mini-stat-lbl">Total Points</div></div>
  </div>`;
  const maxV=Math.max(...PROGRAM.map(d=>perDay[d.id]||0),1);
