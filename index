// --- PRs: which exercise, how many kg ---
function renderStatPRs(){
  const prs=computePRs();
  const names=Object.keys(prs);
  // sort by weight desc
  names.sort((a,b)=>prs[b].weight-prs[a].weight);
  const header=statHeader("PERSONAL RECORDS", names.length+" PR"+(names.length===1?"":"s"), "Your best lift per exercise", "var(--accent)");
  if(!names.length) return header+emptyState("No PRs yet. Finish a workout with weights logged to set your first record.")+`<div class="bottom-spacer"></div>`;
  const rows=names.map(n=>{
    const pr=prs[n];
    const best=Math.max(...pr.history.map(h=>h.weight));
    const last=pr.history[pr.history.length-1];
    return `<div class="pr-row">
      <div class="pr-main">
        <div class="pr-name">${n}</div>
        <div class="pr-reps">target ${pr.reps} reps</div>
      </div>
      <div class="pr-weight ab">${best}<span class="pr-kg">kg</span></div>
    </div>`;
  }).join("");
  return header+`<div class="pr-list">${rows}</div><div class="bottom-spacer"></div>`;
}

// --- SETS: total sets, breakdown per day type + per-exercise volume ---
function renderStatSets(){
  const total=computeTotalSets();
  // sets per day-type
  const perDay={};
  let totalReps=0, totalVolume=0;
  store.log.forEach(e=>{
    const day=PROGRAM.find(d=>d.id===e.dayId);
    Object.values(e.exercises||{}).forEach(ed=>{
      ed.sets.forEach(s=>{
        if(s.done){
          perDay[e.dayId]=(perDay[e.dayId]||0)+1;
          const r=parseInt(s.reps)||0, w=parseFloat(s.weight)||0;
          totalReps+=r; totalVolume+=r*w;
        }
      });
    });
  });
  const header=statHeader("TOTAL SETS", total+" set"+(total===1?"":"s"), "Every completed set you've logged", "var(--accent)");
  if(!total) return header+emptyState("No sets completed yet. Check off sets during a workout to track them here.")+`<div class="bottom-spacer"></div>`;
  const summary=`<div class="mini-stat-row">
    <div class="mini-stat"><div class="mini-stat-val ab">${totalReps.toLocaleString()}</div><div class="mini-stat-lbl">Total Reps</div></div>
    <div class="mini-stat"><div class="mini-stat-val ab">${Math.round(totalVolume).toLocaleString()}</div><div class="mini-stat-lbl">Volume (kg)</div></div>
  </div>`;
  const maxV=Math.max(...PROGRAM.map(d=>perDay[d.id]||0),1);
  const bars=PROGRAM.map(d=>{
    const v=perDay[d.id]||0; const hex=DAY_HEX[d.id];
    return `<div class="setbar-row">
      <div class="setbar-label">${d.title}</div>
      <div class="setbar-track"><div class="setbar-fill" style="width:${Math.round(v/maxV*100)}%;background:${hex}"></div></div>
      <div class="setbar-val">${v}</div>
    </div>`;
  }).join("");
  return header+summary+`<div class="section-label">SETS BY DAY</div><div class="setbar-list">${bars}</div><div class="bottom-spacer"></div>`;
}

// --- DAYS DONE: total completed days, breakdown + recent ---
