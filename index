// RENDER: DAY
// ============================================================
function renderDay(dayId){
  const day=PROGRAM.find(d=>d.id===dayId);
  const hex=DAY_HEX[dayId];
  const draft=store.drafts[dayId]||{exercises:{}};
  const total=day.exercises.reduce((a,e)=>a+e.sets,0);
  const done=day.exercises.reduce((a,e)=>a+((draft.exercises[e.name]?.sets.filter(s=>s.done).length)||0),0);
  const pct=total?Math.round(done/total*100):0;

  const exHtml=day.exercises.map(ex=>{
    const exData=draft.exercises[ex.name]||{sets:Array.from({length:ex.sets},()=>({weight:"",reps:"",done:false}))};
    const comp=exData.sets.filter(s=>s.done).length, full=comp===ex.sets;
    const rows=exData.sets.map((s,i)=>{
      const popCls = (lastToggled===dayId+'|'+ex.name+'|'+i) ? ' pop' : '';
      return `
      <div class="set-row">
        <span class="set-num" style="color:${s.done?hex:'var(--text-faint)'}">${i+1}</span>
        <div class="stepper">
          <button class="step-btn" onclick="stepW('${dayId}','${esc(ex.name)}',${ex.sets},${i},-2.5)">−</button>
          <input class="step-input" type="number" inputmode="decimal" placeholder="0" value="${s.weight}" oninput="setW('${dayId}','${esc(ex.name)}',${ex.sets},${i},this.value)"/>
          <button class="step-btn" onclick="stepW('${dayId}','${esc(ex.name)}',${ex.sets},${i},2.5)">+</button>
        </div>
        <div class="stepper">
          <button class="step-btn" onclick="stepR('${dayId}','${esc(ex.name)}',${ex.sets},${i},-1)">−</button>
          <input class="step-input" type="number" inputmode="numeric" placeholder="0" value="${s.reps}" oninput="setR('${dayId}','${esc(ex.name)}',${ex.sets},${i},this.value)"/>
          <button class="step-btn" onclick="stepR('${dayId}','${esc(ex.name)}',${ex.sets},${i},1)">+</button>
        </div>
        <button class="check-btn${popCls}" style="background:${s.done?hex:'transparent'};border-color:${s.done?hex:'var(--border)'}" onclick="toggleSet('${dayId}','${esc(ex.name)}',${ex.sets},${i},'${hex}')">${s.done?IC.check:''}</button>
      </div>`;
    }).join("");
    return `<div class="ex-card" style="border-color:${full?hex:'var(--border)'}">
      <div class="ex-header">
        <div class="ex-name">${ex.name}<div class="ex-meta">${ex.sets} sets × ${ex.reps} reps</div></div>
        <div class="ex-badge" style="border-color:${full?hex:'var(--border)'};color:${full?hex:'var(--text-faint)'}">${comp}/${ex.sets}</div>
      </div>
      <div class="set-grid">
        <div class="set-head"><span class="set-col-label">SET</span><span class="set-col-label">KG</span><span class="set-col-label">REPS</span><span class="set-col-label">✓</span></div>
        ${rows}
      </div>
    </div>`;
  }).join("");

  const pts=draftPoints(dayId);
  const canFinish=done>0;
  const finishBtn=`<button class="finish-btn ${canFinish?'':'disabled'}" onclick="${canFinish?`openFinishConfirm('${dayId}')`:`toast('Mark at least one set as done first')`}">${IC.flag} Finish Day${pts>0?` · +${pts.toLocaleString()} pts`:''}</button>`;

  return `
    <div class="day-hero">
      <button class="back-btn" onclick="goHome()">${IC.back}</button>
      <div class="day-hero-label">DAY ${day.day}</div>
      <div class="day-hero-title ab" style="color:${hex}">${day.title}</div>
      <div class="day-hero-sub">${day.subtitle}</div>
      <div class="progress-track"><div class="progress-fill" style="width:${pct}%;background:${hex}"></div></div>
      <div class="progress-label">${done}/${total} sets · ${pct}%${pts>0?` · +${pts.toLocaleString()} pts pending`:''}</div>
    </div>
    <div class="ex-list">${exHtml}</div>
    ${finishBtn}
    <div class="bottom-spacer"></div>`;
}

