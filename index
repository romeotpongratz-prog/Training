// ============================================================
// FINISH FLOW
// ============================================================
function openFinishConfirm(dayId){
  if(draftDoneSets(dayId)===0){ toast('Mark at least one set as done first'); return; }
  pendingFinish={dayId, pts:draftPoints(dayId)};
  renderFinishModal('confirm');
}
function confirmFinish(){
  if(!pendingFinish) return;
  const {dayId}=pendingFinish;
  const day=PROGRAM.find(d=>d.id===dayId);
  const draft=store.drafts[dayId]; if(!draft){ closeFinishModal(); return; }
  const pts=draftPoints(dayId);
  const prevPts=totalPoints(); const prevRank=getRank(prevPts);
  const entry={ id:Date.now().toString(36), dayId, date:new Date().toISOString(), exercises:JSON.parse(JSON.stringify(draft.exercises)), points:pts };
  store.log.push(entry);
  delete store.drafts[dayId];
  persist();
  const newRank=getRank(totalPoints());
  pendingFinish={dayId, pts, prevRank, newRank, rankedUp:newRank>prevRank};
  renderFinishModal('success');
}
function renderFinishModal(state){
  const root=document.getElementById("modal-root");
  if(!pendingFinish){ root.innerHTML=""; return; }
  const day=PROGRAM.find(d=>d.id===pendingFinish.dayId);
  if(state==='confirm'){
    root.innerHTML=`<div class="modal-overlay">
      <div class="modal-sheet">
        <div class="modal-title">Finish ${day.title}?</div>
        <div class="modal-text">Your completed sets get saved to History and <b style="color:var(--accent-soft)">+${pendingFinish.pts.toLocaleString()} pts</b> are added to your rank. This day then resets for your next session.</div>
        <div class="modal-actions">
          <button class="modal-btn-ghost" onclick="closeFinishModal()">Cancel</button>
          <button class="modal-btn-primary" onclick="confirmFinish()">Finish</button>
        </div>
      </div>
    </div>`;
  } else {
    const total=totalPoints();
    const nr=RANKS[pendingFinish.newRank];
    const pr=RANKS[pendingFinish.prevRank];
    root.innerHTML=`<div class="modal-overlay">
      <div class="modal-sheet">
        <div class="modal-emblem">${rankEmblem(nr.tier,64,true)}</div>
        <div class="modal-eyebrow">DAY COMPLETE</div>
        <div class="modal-title-lg ab">${day.title}</div>
        <div class="modal-points ab">+${pendingFinish.pts.toLocaleString()}<span> pts</span></div>
        ${pendingFinish.rankedUp?`<div class="rank-up-badge">RANK UP — ${pr.name} → ${nr.name}</div>`:''}
        <div class="modal-total">Total ${total.toLocaleString()} pts · ${nr.name}</div>
        <button class="modal-btn-primary full" onclick="closeFinishToHome()">Done</button>
      </div>
    </div>`;
    if(pendingFinish.rankedUp && navigator.vibrate) navigator.vibrate([60,40,60,40,120]);
  }
}
function closeFinishModal(){ pendingFinish=null; document.getElementById("modal-root").innerHTML=""; }
function closeFinishToHome(){ pendingFinish=null; document.getElementById("modal-root").innerHTML=""; goHome(); }

// ============================================================
// TIMER
// ============================================================
function openTimer(hex){
  if(timerState.iv) clearInterval(timerState.iv);
  timerState={open:true,hex,secs:90,total:90,running:true,iv:null};
  startTimerLoop(); renderTimerUI();
}
function closeTimer(){ if(timerState.iv) clearInterval(timerState.iv); timerState.open=false; document.getElementById("timer-root").innerHTML=""; }
function startTimerLoop(){
  if(timerState.iv) clearInterval(timerState.iv);
  timerState.iv=setInterval(()=>{
    if(!timerState.running) return;
    if(timerState.secs<=0){clearInterval(timerState.iv);timerState.running=false;if(navigator.vibrate)navigator.vibrate([200,80,200]);renderTimerUI();return;}
    timerState.secs--; renderTimerUI();
  },1000);
}
function timerAdj(d){timerState.secs=Math.max(0,timerState.secs+d);renderTimerUI();}
function timerToggle(){timerState.running=!timerState.running;if(timerState.running)startTimerLoop();renderTimerUI();}
function timerReset(){timerState.secs=90;timerState.running=true;startTimerLoop();renderTimerUI();}
function renderTimerUI(){
  const root=document.getElementById("timer-root");
  if(!root||!timerState.open) return;
  const pct=(timerState.secs/timerState.total)*100;
  const mm=String(Math.floor(timerState.secs/60)).padStart(2,"0");
  const ss=String(timerState.secs%60).padStart(2,"0");
  root.innerHTML=`<div class="timer-overlay">
    <div class="timer-card">
      <button class="timer-close" onclick="closeTimer()">${IC.close}</button>
      <div class="timer-ring-outer" style="background:conic-gradient(${timerState.hex} ${pct}%,var(--surface-2) 0)">
        <div class="timer-ring-inner"><span class="timer-time ab">${mm}:${ss}</span><span class="timer-sub">REST</span></div>
      </div>
      <div class="timer-controls">
        <button class="timer-btn" onclick="timerAdj(-15)">−15s</button>
        <button class="timer-btn" style="background:${timerState.hex};border-color:${timerState.hex}" onclick="timerToggle()">${timerState.running?IC.pause:IC.play}</button>
        <button class="timer-btn" onclick="timerAdj(15)">+15s</button>
      </div>
      <button class="timer-reset-btn" onclick="timerReset()">${IC.reset} reset</button>
    </div>
  </div>`;
}

// ============================================================
// TOAST + NAV + RENDER
// ============================================================
function toast(msg){
  let t=document.getElementById('toast');
  if(!t){ t=document.createElement('div'); t.id='toast'; document.body.appendChild(t); }
  t.textContent=msg; t.className='show';
  clearTimeout(window._tt); window._tt=setTimeout(()=>{ t.className=''; },2200);
}
function esc(s){return s.replace(/'/g,"\\'");}
function setW(dayId,exName,setCount,idx,val){ensureEx(dayId,exName,setCount).sets[idx].weight=val;persist();}
function setR(dayId,exName,setCount,idx,val){ensureEx(dayId,exName,setCount).sets[idx].reps=val;persist();}
function stepW(dayId,exName,setCount,idx,delta){
  const ex=ensureEx(dayId,exName,setCount);
  let cur=parseFloat(ex.sets[idx].weight)||0;
  cur=Math.max(0,Math.round((cur+delta)*10)/10);
  ex.sets[idx].weight=String(cur); persist();
  if(navigator.vibrate)navigator.vibrate(6); render();
}
function stepR(dayId,exName,setCount,idx,delta){
  const ex=ensureEx(dayId,exName,setCount);
  let cur=parseInt(ex.sets[idx].reps)||0;
  cur=Math.max(0,cur+delta);
  ex.sets[idx].reps=String(cur); persist();
  if(navigator.vibrate)navigator.vibrate(6); render();
}
function toggleSet(dayId,exName,setCount,idx,hex){
  const ex=ensureEx(dayId,exName,setCount);
  const was=ex.sets[idx].done;
  ex.sets[idx].done=!was; persist();
  if(!was){ lastToggled=dayId+'|'+exName+'|'+idx; if(navigator.vibrate)navigator.vibrate(40); }
  render();
  if(!was)openTimer(hex);
}
function goDay(dayId){currentView="day";currentDayId=dayId;animateNext=true;render();window.scrollTo(0,0);}
function goSwipe(i){ swipeIndex=Math.max(0,Math.min(PROGRAM.length-1,i)); updateSwipe(); }
function goHome(){currentView="home";currentDayId=null;animateNext=true;render();window.scrollTo(0,0);}
function goStats(){currentView="stats";currentDayId=null;animateNext=true;render();window.scrollTo(0,0);}
function goRank(){currentView="rank";currentDayId=null;animateNext=true;render();window.scrollTo(0,0);}
function goStat(which){currentView="stat";currentDayId=which;animateNext=true;render();window.scrollTo(0,0);}

function render(){
  let html="";
  if(currentView==="home") html=renderHome();
  else if(currentView==="day") html=renderDay(currentDayId);
  else if(currentView==="stats") html=renderStats();
  else if(currentView==="rank") html=renderRank();
  else if(currentView==="stat") html=renderStat(currentDayId);
  const wrapCls = animateNext ? "view-anim" : "view-static";
  const nav=currentView!=="day"?`
    <nav class="bottom-nav">
      <button class="nav-btn ${currentView==='home'?'active':''}" onclick="goHome()">${IC.home}HOME</button>
      <button class="nav-btn ${currentView==='stats'?'active':''}" onclick="goStats()">${IC.chart}STATS</button>
    </nav>`:"";
  document.getElementById("app").innerHTML=`<div class="${wrapCls}">${html}</div>`+nav;
  animateNext=false;
  if(lastToggled){ lastToggled=null; }
  if(currentView==="home") bindSwipe();
}

function updateSwipe(){
  const track=document.getElementById("swipe-track");
  if(track) track.style.transform=`translateX(-${swipeIndex*100}%)`;
  document.querySelectorAll(".swipe-dot").forEach((d,i)=>{
    const hex=DAY_HEX[PROGRAM[i].id];
    if(i===swipeIndex){ d.classList.add("active"); d.style.background=hex; d.style.width="22px"; }
    else { d.classList.remove("active"); d.style.background=""; d.style.width=""; }
  });
}

function bindSwipe(){
  const vp=document.getElementById("swipe-viewport");
  const track=document.getElementById("swipe-track");
  if(!vp||!track) return;
  let x0=null, y0=null, dx=0, dragging=false, decided=false, horiz=false;
  vp.addEventListener("touchstart",e=>{
    x0=e.touches[0].clientX; y0=e.touches[0].clientY; dx=0; dragging=true; decided=false; horiz=false;
    track.style.transition="none";
  },{passive:true});
  vp.addEventListener("touchmove",e=>{
    if(!dragging) return;
    const cx=e.touches[0].clientX, cy=e.touches[0].clientY;
    dx=cx-x0; const dy=cy-y0;
    if(!decided){ decided=true; horiz=Math.abs(dx)>Math.abs(dy); }
    if(horiz){
      e.preventDefault();
      const w=vp.clientWidth;
      let off=-swipeIndex*w+dx;
      // rubber-band at edges
      if((swipeIndex===0&&dx>0)||(swipeIndex===PROGRAM.length-1&&dx<0)) off=-swipeIndex*w+dx*0.32;
      track.style.transform=`translateX(${off}px)`;
    }
  },{passive:false});
  const end=()=>{
    if(!dragging) return; dragging=false;
    track.style.transition="";
    const w=vp.clientWidth;
    if(horiz && Math.abs(dx)>w*0.18){
      if(dx<0 && swipeIndex<PROGRAM.length-1) swipeIndex++;
      else if(dx>0 && swipeIndex>0) swipeIndex--;
      if(navigator.vibrate) navigator.vibrate(8);
    }
    updateSwipe();
  };
  vp.addEventListener("touchend",end,{passive:true});
  vp.addEventListener("touchcancel",end,{passive:true});
}

window.goDay=goDay;window.goHome=goHome;window.goStats=goStats;window.goSwipe=goSwipe;window.goRank=goRank;window.goStat=goStat;
window.setW=setW;window.setR=setR;window.stepW=stepW;window.stepR=stepR;window.toggleSet=toggleSet;
window.openFinishConfirm=openFinishConfirm;window.confirmFinish=confirmFinish;
window.closeFinishModal=closeFinishModal;window.closeFinishToHome=closeFinishToHome;
window.closeTimer=closeTimer;window.timerAdj=timerAdj;window.timerToggle=timerToggle;window.timerReset=timerReset;
window.toast=toast;

// Intro / splash
let animateNext = true;
function enterApp(){
  if(navigator.vibrate) navigator.vibrate(30);
  const intro=document.getElementById("intro");
  const app=document.getElementById("app");
  intro.classList.add("hide");
  app.classList.add("entered");
  animateNext=true;
  render();
  setTimeout(()=>{ intro.style.display="none"; }, 600);
}
window.enterApp=enterApp;
