        <path d="M11.4316 7.6193C10.5274 6.71511 10.0753 6.26301 10.0108 5.71092C9.9964 5.58768 9.9964 5.46318 10.0108 5.33994C10.0753 4.78785 10.5274 4.33576 11.4316 3.43156C12.3358 2.52737 12.7879 2.07528 13.3399 2.0108C13.4632 1.9964 13.5877 1.9964 13.7109 2.0108C14.263 2.07528 14.7151 2.52737 15.6193 3.43156L20.5684 8.3807C21.4726 9.28489 21.9247 9.73699 21.9892 10.2891C22.0036 10.4123 22.0036 10.5368 21.9892 10.6601C21.9247 11.2122 21.4726 11.6642 20.5684 12.5684C19.6642 13.4726 19.2122 13.9247 18.6601 13.9892C18.5368 14.0036 18.4123 14.0036 18.2891 13.9892C17.737 13.9247 17.2849 13.4726 16.3807 12.5684L11.4316 7.6193Z"/>
        <path opacity="0.55" d="M18.0188 2.49805L21.1228 5.60206" stroke-linecap="round" stroke-linejoin="round"/>
        <path opacity="0.55" d="M2.49756 18.0186L5.60157 21.1226" stroke-linecap="round" stroke-linejoin="round"/>
      </g>
    </svg>
  </button>
  <div class="intro-touch">Touch to continue</div>
</div>
<div id="app"></div>
<div id="timer-root"></div>
<div id="modal-root"></div>

<script>
// ============================================================
// DATA
// ============================================================
const PROGRAM = [
  { id:"push", day:1, title:"Push", subtitle:"Chest · Shoulders · Triceps",
    exercises:[
      {name:"Barbell Bench Press", sets:4, reps:"6–8"},
      {name:"Incline DB Press", sets:3, reps:"8–10"},
      {name:"Chest Press Machine", sets:3, reps:"10–12"},
      {name:"Shoulder Press Machine", sets:4, reps:"8–10"},
      {name:"Cable Lateral Raise", sets:4, reps:"12–15"},
      {name:"Tricep Pushdown Cable", sets:3, reps:"10–12"},
      {name:"Overhead Tricep Cable", sets:3, reps:"12–15"},
    ]},
  { id:"pull", day:2, title:"Pull", subtitle:"Back · Biceps",
    exercises:[
      {name:"Pull-Ups / Lat Pulldown", sets:4, reps:"6–10"},
      {name:"Row Machine", sets:4, reps:"8–12"},
      {name:"T-Bar Row", sets:3, reps:"8–10"},
      {name:"Close Grip Lat Pulldown", sets:3, reps:"10–12"},
      {name:"Face Pulls", sets:3, reps:"12–15"},
      {name:"Bicep Curl Machine", sets:3, reps:"10–12"},
      {name:"Hammer Curls", sets:3, reps:"10–12"},
    ]},
  { id:"legs", day:3, title:"Legs", subtitle:"Strong Foundation",
    exercises:[
      {name:"Squats", sets:4, reps:"6–8"},
      {name:"Leg Press", sets:4, reps:"10–12"},
      {name:"Romanian Deadlift", sets:3, reps:"8–10"},
      {name:"Leg Curl Machine", sets:3, reps:"10–12"},
      {name:"Leg Extension", sets:3, reps:"12–15"},
      {name:"Calf Raise Machine", sets:4, reps:"12–20"},
      {name:"Hanging Leg Raises", sets:3, reps:"15"},
    ]},
  { id:"toji", day:4, title:"Special", subtitle:"Shoulders & Arms",
    exercises:[
      {name:"Shoulder Press", sets:4, reps:"8–10"},
      {name:"Lateral Raise Machine", sets:4, reps:"15"},
      {name:"Cable Lateral Raise", sets:3, reps:"15"},
      {name:"Reverse Fly Machine", sets:4, reps:"12–15"},
      {name:"EZ-Bar Curls", sets:4, reps:"8–10"},
      {name:"Hammer Curls", sets:3, reps:"10–12"},
      {name:"Tricep Pushdown", sets:4, reps:"10–12"},
      {name:"Dips", sets:3, reps:"near failure"},
    ]},
  { id:"upper", day:5, title:"Upper Body", subtitle:"Focus Session",
    exercises:[
      {name:"Incline Bench Press", sets:4, reps:"8"},
      {name:"Pull-Ups", sets:4, reps:"max"},
      {name:"Row Machine", sets:3, reps:"10"},
      {name:"Chest Press", sets:3, reps:"12"},
      {name:"Lateral Raise", sets:3, reps:"15"},
      {name:"Face Pulls", sets:3, reps:"15"},
      {name:"Cable Crunches", sets:3, reps:"15"},
    ]},
];

const DAY_HEX = { push:"#3B82F6", pull:"#7DA9F0", legs:"#3B82F6", toji:"#7DA9F0", upper:"#3B82F6" };

const RANKS = [
  { name:"Bronze",      tier:1, min:0,     max:499,   desc:"0 – 499 pts",        challenge:{ ex:"Barbell Bench Press", kg:40 } },
  { name:"Silver",      tier:2, min:500,   max:1499,  desc:"500 – 1,499 pts",    challenge:{ ex:"Barbell Bench Press", kg:60 } },
  { name:"Gold",        tier:3, min:1500,  max:3499,  desc:"1,500 – 3,499 pts",  challenge:{ ex:"Squats", kg:80 } },
  { name:"Platinum",    tier:4, min:3500,  max:6999,  desc:"3,500 – 6,999 pts",  challenge:{ ex:"Squats", kg:100 } },
  { name:"Diamond",     tier:5, min:7000,  max:12999, desc:"7,000 – 12,999 pts", challenge:{ ex:"Romanian Deadlift", kg:120 } },
  { name:"Master",      tier:6, min:13000, max:24999, desc:"13,000 – 24,999 pts",challenge:{ ex:"Squats", kg:140 } },
  { name:"Grandmaster", tier:7, min:25000, max:Infinity, desc:"25,000+ pts",     challenge:{ ex:"Romanian Deadlift", kg:160 } },
];

function rankEmblem(tier, size, active) {
  const stroke = active ? "#7DA9F0" : "#2E3440";
  const fill = active ? "#3B82F6" : "#161A22";
  const pipColor = active ? '#EAEEF5' : '#3A414E';
  const crownColor = active ? '#FFD24A' : '#3A414E';

  const hasCrown = tier >= 6;
  // chevron pips: 1..3 based on tier (tiers 1-3 add pips; 4-7 keep 3)
  const n = Math.min(tier, 3);

  // Vertical layout INSIDE the shield. Shield inner area roughly y:6..17, x:7..17
  const crown = hasCrown
    ? `<path d="M9 6.3 L10.6 7.7 L12 5.6 L13.4 7.7 L15 6.3 L14.3 9.2 L9.7 9.2 Z" fill="${crownColor}" stroke="${active?'#E0B83A':'#333a46'}" stroke-width="0.4" stroke-linejoin="round"/>`
    : "";

  // start chevrons lower if crown present, keep them centered and narrow
  const startY = hasCrown ? 10.4 : 8.4;
  const gap = hasCrown ? 2.5 : 3.1;
  let chevrons = "";
  for (let i = 0; i < n; i++) {
    const y = startY + i * gap;
    chevrons += `<path d="M8.8 ${y+2.2} L12 ${y} L15.2 ${y+2.2}" fill="none" stroke="${pipColor}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`;
  }

  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24">
    <path d="M12 2 L20 5.2 V11 C20 16 16.4 19.6 12 21.6 C7.6 19.6 4 16 4 11 V5.2 Z" fill="${fill}" stroke="${stroke}" stroke-width="1.3" stroke-linejoin="round"/>
    ${crown}${chevrons}
  </svg>`;
}

function pointsForSet(weight, repsStr, repTarget) {
  const w = parseFloat(weight);
  if (isNaN(w)||w<=0) return 0;
  let reps = parseInt(repsStr);
  if (isNaN(reps)||reps<=0) reps = parseInt(repTarget.split(/[–-]/)[0]) || 8;
  return Math.round(w*reps);
}
function getRank(pts){ for(let i=RANKS.length-1;i>=0;i--) if(pts>=RANKS[i].min) return i; return 0; }

// ============================================================
// STORAGE  —  { drafts:{dayId:{exercises:{}}}, log:[ {id,dayId,date,exercises,points} ] }
// ============================================================
const STORAGE_KEY = "toji-tracker-v4";
function load() {
  try { const d=JSON.parse(localStorage.getItem(STORAGE_KEY)); if(d&&d.drafts&&d.log) return d; } catch {}
  return { drafts:{}, log:[] };
}
function save(d){ try { localStorage.setItem(STORAGE_KEY, JSON.stringify(d)); } catch {} }
function todayKey(){ return new Date().toISOString().slice(0,10); }
function fmtDate(d){ return new Date(d).toLocaleDateString("en-US",{weekday:"short",month:"short",day:"numeric"}); }

let store = load();
let currentView = "home";
let currentDayId = null;
let timerState = { open:false, hex:"#3B82F6", secs:90, total:90, running:false, iv:null };
let pendingFinish = null;
let lastToggled = null;
let swipeIndex = 0;

function persist(){ save(store); }

// DRAFT helpers
function getDraft(dayId){ if(!store.drafts[dayId]) store.drafts[dayId]={exercises:{}}; return store.drafts[dayId]; }
function ensureEx(dayId, exName, setCount){
  const d=getDraft(dayId);
  if(!d.exercises[exName]) d.exercises[exName]={sets:Array.from({length:setCount},()=>({weight:"",reps:"",done:false}))};
  return d.exercises[exName];
}
function draftDoneSets(dayId){
  const d=store.drafts[dayId]; if(!d) return 0;
  return Object.values(d.exercises||{}).reduce((a,ed)=>a+ed.sets.filter(s=>s.done).length,0);
}

// POINTS
function exPoints(day, exercisesData){
  let pts=0;
  Object.entries(exercisesData||{}).forEach(([n,ed])=>{
    const ex=day.exercises.find(e=>e.name===n); if(!ex) return;
    ed.sets.forEach(s=>{ if(s.done) pts+=pointsForSet(s.weight,s.reps,ex.reps); });
  });
  return pts;
}
function draftPoints(dayId){ const day=PROGRAM.find(d=>d.id===dayId); return exPoints(day, store.drafts[dayId]?.exercises); }
function totalPoints(){ return store.log.reduce((a,e)=>a+(e.points||0),0); }

// FROM LOG: PRs, streak, totals
function computePRs(){
  const prs={};
  [...store.log].sort((a,b)=>a.date<b.date?-1:1).forEach(entry=>{
    const day=PROGRAM.find(d=>d.id===entry.dayId); if(!day) return;
    Object.entries(entry.exercises||{}).forEach(([n,ed])=>{
      const ex=day.exercises.find(e=>e.name===n); if(!ex) return;
      ed.sets.forEach(s=>{
        const w=parseFloat(s.weight);
        if(s.done&&!isNaN(w)&&w>0){
          if(!prs[n]) prs[n]={weight:0,history:[],reps:ex.reps};
          if(w>prs[n].weight) prs[n].weight=w;
          prs[n].history.push({date:entry.date.slice(0,10),weight:w});
        }
      });
    });
  });
  return prs;
}
function computeStreak(){
  const dates=new Set(store.log.map(e=>e.date.slice(0,10)));
  const c=new Date(); let s=0;
  for(let i=0;i<365;i++){
    const k=c.toISOString().slice(0,10);
    if(dates.has(k)){s++;c.setDate(c.getDate()-1);}
    else if(k===todayKey()){c.setDate(c.getDate()-1);}
    else break;
  }
  return s;
}
function completedToday(){
  return store.log.some(e=>e.date.slice(0,10)===todayKey());
}
function computeTotalSets(){
  let n=0;
  store.log.forEach(e=>Object.values(e.exercises||{}).forEach(ed=>{n+=ed.sets.filter(s=>s.done).length;}));
  return n;
}

// ============================================================
// ICONS
// ============================================================
const IC = {
  back:`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#EAEEF5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>`,
  check:`<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0A0C10" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>`,
  close:`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>`,
  play:`<svg width="16" height="16" viewBox="0 0 24 24" fill="#0A0C10"><path d="M8 5v14l11-7z"/></svg>`,
  pause:`<svg width="16" height="16" viewBox="0 0 24 24" fill="#0A0C10"><path d="M6 4h4v16H6zM14 4h4v16h-4z"/></svg>`,
  reset:`<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#424955" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg>`,
  flag:`<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#0A0C10" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 21V4M5 4h12l-2.5 4 2.5 4H5"/></svg>`,
  flame:`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" stroke-linejoin="round"><path d="M12 2c1 4-3 5-3 9a3 3 0 006 0c1-1 1-3 0-4 2 1 3 3 3 5a6 6 0 11-12 0c0-5 4-6 6-10z"/></svg>`,
  flameLit:`<svg width="64" height="64" viewBox="0 0 24 24"><defs><linearGradient id="flameG" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#FFD24A"/><stop offset="0.5" stop-color="#FF8A1E"/><stop offset="1" stop-color="#FF5722"/></linearGradient></defs><path d="M12 2c1 4-3 5-3 9a3 3 0 006 0c1-1 1-3 0-4 2 1 3 3 3 5a6 6 0 11-12 0c0-5 4-6 6-10z" fill="url(#flameG)"/><path d="M12 13c.6 1.2-.4 2-.4 3.2a1.4 1.4 0 002.8 0c0-.8-.5-1.4-.5-2.2.9.5 1.3 1.4 1.3 2.4a2.6 2.6 0 11-5.2 0c0-2 1.4-2.6 2-3.4z" fill="#FFE9A8"/></svg>`,
  flameDead:`<svg width="64" height="64" viewBox="0 0 24 24"><path d="M12 2c1 4-3 5-3 9a3 3 0 006 0c1-1 1-3 0-4 2 1 3 3 3 5a6 6 0 11-12 0c0-5 4-6 6-10z" fill="#1A1E27" stroke="#2B313D" stroke-width="1.4" stroke-linejoin="round"/></svg>`,
  sets:`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" stroke-linecap="round"><path d="M6.5 6.5l11 11M4 8l4-4m8 16l4-4M3 9l2-2m12 12l2-2"/></svg>`,
  trophy:`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" stroke-linejoin="round"><path d="M7 4h10v3a5 5 0 01-10 0V4zM5 5H3v1.5a3.5 3.5 0 003.5 3.5M19 5h2v1.5a3.5 3.5 0 01-3.5 3.5M9 16h6v3H9z"/></svg>`,
  trophyDark:`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0A0C10" stroke-width="2" stroke-linejoin="round"><path d="M7 4h10v3a5 5 0 01-10 0V4zM5 5H3v1.5a3.5 3.5 0 003.5 3.5M19 5h2v1.5a3.5 3.5 0 01-3.5 3.5M9 16h6v3H9z"/></svg>`,
  home:`<svg class="nav-ic" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#424955" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10l9-7 9 7v10a1 1 0 01-1 1h-5v-7H9v7H4a1 1 0 01-1-1z"/></svg>`,
  chart:`<svg class="nav-ic" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#424955" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/></svg>`,
  chevron:`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#424955" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>`,
  check2:`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3DD68C" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>`,
};

// ============================================================
// RENDER: HOME
// ============================================================
function renderHome(){
  const pts=totalPoints();
  const ri=getRank(pts), rank=RANKS[ri], next=RANKS[ri+1];
  const pctBar=next?Math.round(((pts-rank.min)/(next.min-rank.min))*100):100;
  const streak=computeStreak(), totalSets=computeTotalSets(), prCount=Object.keys(computePRs()).length;
  const litToday=completedToday();

  // Swipe day preview cards
  if(swipeIndex<0) swipeIndex=0;
  if(swipeIndex>PROGRAM.length-1) swipeIndex=PROGRAM.length-1;
  const slides=PROGRAM.map(day=>{
    const exData=store.drafts[day.id]?.exercises||{};
    const tot=day.exercises.reduce((a,e)=>a+e.sets,0);
    const doneS=day.exercises.reduce((a,e)=>a+((exData[e.name]?.sets.filter(s=>s.done).length)||0),0);
    const p=tot?Math.round(doneS/tot*100):0;
    const hex=DAY_HEX[day.id];
    const inProgress=draftDoneSets(day.id);
    return `<button class="swipe-card" style="border-color:${p>0?hex:'var(--border)'}" onclick="goDay('${day.id}')">
      <div class="swipe-card-glow" style="background:${hex}"></div>
      <div class="swipe-day-num ab" style="color:${hex}">DAY ${day.day}</div>
      <div class="swipe-day-title ab">${day.title}</div>
      <div class="swipe-day-sub">${day.subtitle}</div>
      <div class="swipe-card-foot">
        <div class="swipe-meta">${day.exercises.length} exercises</div>
        ${inProgress>0?`<div class="swipe-progress" style="color:${hex}">${p}% · ${inProgress} in progress</div>`:`<div class="swipe-tap">Tap to open</div>`}
      </div>
    </button>`;
  }).join("");

  const dots=PROGRAM.map((day,i)=>{
    const hex=DAY_HEX[day.id];
    return `<button class="swipe-dot ${i===swipeIndex?'active':''}" style="${i===swipeIndex?`background:${hex};width:22px`:''}" onclick="goSwipe(${i})" aria-label="Day ${day.day}"></button>`;
  }).join("");

  return `
    <div class="home-header">
      <div class="brand-lockup">
        <span class="brand-word ab">Training</span>
      </div>
    </div>
    <div class="streak-card ${litToday?'lit':'dead'}">
      ${litToday?'<div class="streak-glow"></div>':''}
      <div class="streak-flame">${litToday?IC.flameLit:IC.flameDead}</div>
      <div class="streak-num ab" style="color:${litToday?'#FF8A1E':'var(--text-faint)'}">${streak}</div>
      <div class="streak-unit">${streak===1?'day streak':'day streak'}</div>
    </div>
    <button class="rank-card rank-card-btn" onclick="goRank()">
      <div class="rank-card-glow"></div>
      <div class="rank-top">
        <div class="rank-emblem-wrap">${rankEmblem(rank.tier,56,true)}</div>
        <div>
          <div class="rank-label">CURRENT RANK</div>
          <div class="rank-name ab">${rank.name}</div>
          <div class="rank-pts">${pts.toLocaleString()} pts${next?'':' · MAX'}</div>
        </div>
        <div class="rank-card-arrow">${IC.chevron}</div>
      </div>
      <div class="rank-bar-track"><div class="rank-bar-fill" style="width:${pctBar}%;background:linear-gradient(90deg,var(--accent),var(--accent-soft))"></div></div>
      <div class="rank-bar-labels">
        <span>${rank.name}</span>
        <span>${next?`${(next.min-pts).toLocaleString()} to ${next.name}`:'Grandmaster'}</span>
      </div>
    </button>
    <div class="stat-row">
      <button class="stat-chip" onclick="goStat('days')"><span class="stat-chip-ic">${IC.trophy}</span><span class="stat-chip-val ab">${store.log.length}</span><span class="stat-chip-label">Days Done</span></button>
      <button class="stat-chip" onclick="goStat('sets')"><span class="stat-chip-ic">${IC.sets}</span><span class="stat-chip-val ab">${totalSets}</span><span class="stat-chip-label">Sets</span></button>
