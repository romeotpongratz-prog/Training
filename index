        }).join("");
        const exPts=d.history.reduce((a,h)=>a+Math.round(h.weight*(parseInt(d.reps)||8)),0);
        return `<div class="pr-card">
          <div class="pr-card-header">
            <div><div class="pr-card-name">${n}</div><div class="pr-card-pts">+${exPts.toLocaleString()} pts logged</div></div>
            <div class="pr-card-weight">${d.weight} kg</div>
          </div>
          ${hist.length>1?`<div class="mini-chart">${bars}</div>`:''}
        </div>`;
      }).join("");

  const logSorted=[...store.log].sort((a,b)=>a.date<b.date?1:-1).slice(0,20);
  const histHtml=logSorted.length===0
    ? `<div class="empty-state">No sessions yet.<br>Complete a day to see it here.</div>`
