}

function renderRank(){
  const pts=totalPoints(), ri=getRank(pts);
  const rank=RANKS[ri], next=RANKS[ri+1];
  const prs=computePRs();
  const pctBar=next?Math.round(((pts-rank.min)/(next.min-rank.min))*100):100;
  const needed=next?next.min-pts:0;

  // Build a challenge row for each rank
